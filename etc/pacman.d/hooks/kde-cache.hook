[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = kservice
Target = kconfig
Target = kio
Target = knewstuff
Target = kparts
Target = kfilemetadata
Target = plasma-framework
Target = kded

[Action]
Description = Reconstruindo cache KDE (kbuildsycoca6)...
When = PostTransaction
Exec = /bin/sh -c 'for d in /home/*; do [ -d "$d" ] && rm -f "$d/.cache/ksycoca6_"* && runuser -u "$(basename "$d")" /usr/bin/kbuildsycoca6 --noincremental 2>/dev/null; done'
